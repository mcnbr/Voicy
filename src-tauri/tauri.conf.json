{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Voicy",
  "version": "0.0.0",
  "identifier": "com.voicy.app",
  "build": {
    "devUrl": "http://localhost:5173",
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "title": "Voicy",
        "width": 1000,
        "height": 700,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}